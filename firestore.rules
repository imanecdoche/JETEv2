rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9\\-_]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'active', 'role', 'ownerId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.active is bool
        && data.role is string && data.role.size() <= 50
        && data.ownerId == request.auth.uid
        && (!data.keys().contains('email') || data.email is string)
        && (!data.keys().contains('phone') || data.phone is string)
        && (!data.keys().contains('photoUrl') || data.photoUrl is string)
        && (!data.keys().contains('dob') || data.dob is string)
        && (!data.keys().contains('gender') || data.gender is string)
        && (!data.keys().contains('address') || data.address is string)
        && (!data.keys().contains('emergencyContact') || data.emergencyContact is string)
        && (!data.keys().contains('identityNo') || data.identityNo is string)
        && (!data.keys().contains('npwp') || data.npwp is string)
        && (!data.keys().contains('targets') || data.targets is map)
        && (!data.keys().contains('language') || data.language is string)
        && (!data.keys().contains('adaptMode') || data.adaptMode is string)
        && (!data.keys().contains('sessionActiveId') || data.sessionActiveId is string)
        && (!data.keys().contains('sessionLastActive') || data.sessionLastActive is number);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'qty', 'gram', 'price', 'customerName', 'date', 'timestamp', 'ownerId'])
        && data.userId is string && data.userId.size() > 0
        && data.type is string && data.type.size() > 0
        && data.price is number
        && data.ownerId == request.auth.uid;
    }

    function isValidTransactionSummary(data) {
      return data.keys().hasAll(['date', 'source', 'categories', 'totalTransactions', 'createdBy', 'timestamp', 'ownerId'])
        && data.ownerId == request.auth.uid;
    }

    function isValidTarget(data) {
       return data.keys().hasAll(['daily', 'weekly', 'monthly', 'ownerId'])
         && data.ownerId == request.auth.uid;
    }

    function isValidLmTransaction(data) {
      return data.keys().hasAll(['type', 'customerName', 'customerPhone', 'date', 'timestamp', 'ownerId', 'items', 'totalGram', 'totalPrice'])
        && data.type is string
        && data.customerName is string
        && data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidTransaction(incoming());
      allow delete: if isSignedIn() && isOwner(existing());
    }
    
    match /transaction_summaries/{summaryId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransactionSummary(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidTransactionSummary(incoming());
      allow delete: if isSignedIn() && isOwner(existing());
    }

    match /lm_transactions/{transactionId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidLmTransaction(incoming());
      allow update: if isSignedIn() && isOwner(existing()) && isValidLmTransaction(incoming());
      allow delete: if isSignedIn() && isOwner(existing());
    }

    match /settings/{settingId} {
       allow get: if isSignedIn() && (resource == null || settingId == "app_targets_" + request.auth.uid);
       allow list: if false;
       allow write: if isSignedIn() && isValidTarget(incoming());
    }
  }
}
